package database

import (
	"context"
	"database/sql"
	"fmt"
	"strings"

{{- if .WithOpenTelemetry }}
	"github.com/XSAM/otelsql"
	"go.opentelemetry.io/otel/attribute"
{{ end }}
	"{{ .ModulePath }}/internal/config"
)

func Open(ctx context.Context, cfg config.DatabaseConfig) (*sql.DB, error) {
	if err := ctx.Err(); err != nil {
		return nil, err
	}
	if strings.TrimSpace(cfg.DSN) == "" {
		return nil, nil
	}
	if strings.TrimSpace(cfg.Driver) == "" {
		return nil, fmt.Errorf("database driver is required when DB_DSN is set")
	}

	db, err := openSQLDatabase(cfg)
	if err != nil {
		return nil, err
	}
	if err := db.PingContext(ctx); err != nil {
		_ = db.Close()
		return nil, err
	}
	return db, nil
}

func openSQLDatabase(cfg config.DatabaseConfig) (*sql.DB, error) {
{{- if .WithOpenTelemetry }}
	return otelsql.Open(cfg.Driver, cfg.DSN,
		otelsql.WithAttributes(attribute.String("db.system.name", cfg.Driver)),
		otelsql.WithSpanOptions(otelsql.SpanOptions{
			Ping:           true,
			DisableErrSkip: true,
		}),
	)
{{- else }}
	return sql.Open(cfg.Driver, cfg.DSN)
{{- end }}
}
