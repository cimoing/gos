package http

import (
	"net/http"
	"time"

	"{{ .ModulePath }}/internal/interfaces/http/middleware"
	"{{ .ModulePath }}/internal/pkg/response"
{{- if .WithOpenTelemetry }}
	"go.opentelemetry.io/contrib/instrumentation/net/http/otelhttp"
{{- end }}
)

type RouterOptions struct {
	TraceHTTP    bool
	ServiceName  string
	MaxBodyBytes int64
}

func NewRouter(options ...RouterOptions) http.Handler {
	var opts RouterOptions
	if len(options) > 0 {
		opts = options[0]
	}
	mux := http.NewServeMux()

	mux.HandleFunc("GET /healthz", func(w http.ResponseWriter, r *http.Request) {
		response.JSON(w, http.StatusOK, response.Success(map[string]string{
			"status": "ok",
		}))
	})

	handler := middleware.Chain(
		mux,
		middleware.RequestID(),
		middleware.Recover(),
		middleware.CORS(middleware.CORSOptions{}),
		middleware.AccessLog(),
		middleware.Timeout(10*time.Second),
	)
	if opts.MaxBodyBytes > 0 {
		handler = http.MaxBytesHandler(handler, opts.MaxBodyBytes)
	}
{{ if .WithOpenTelemetry }}
	if opts.TraceHTTP {
		return otelhttp.NewHandler(handler, opts.ServiceName)
	}
{{ end }}
	return handler
}
