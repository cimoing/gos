package logging

import (
	"bytes"
	"strings"
	"testing"

	"{{ .ModulePath }}/internal/config"
)

func TestLoggerRedactsSensitiveFields(t *testing.T) {
	var output bytes.Buffer
	logger, err := NewWithWriter(config.LogConfig{Level: "info"}, &output)
	if err != nil {
		t.Fatalf("NewWithWriter() error = %v", err)
	}

	logger.Info("user login", "username", "alice", "password", "secret", "authorization", "Bearer token")

	got := output.String()
	if strings.Contains(got, "secret") || strings.Contains(got, "Bearer token") {
		t.Fatalf("expected sensitive fields to be redacted, got %s", got)
	}
	if !strings.Contains(got, "[REDACTED]") {
		t.Fatalf("expected redacted marker, got %s", got)
	}
	if !strings.Contains(got, "alice") {
		t.Fatalf("expected non-sensitive field to remain, got %s", got)
	}
}
