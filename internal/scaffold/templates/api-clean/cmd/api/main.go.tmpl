package main

import (
	"context"
	"log"
	"log/slog"
	"os"
	"os/signal"
	"syscall"
	"time"

	"{{ .ModulePath }}/internal/app"
	"{{ .ModulePath }}/internal/config"
	"{{ .ModulePath }}/internal/logging"
	"{{ .ModulePath }}/internal/worker"
	"github.com/spf13/cobra"
	// gos:command-imports
)

func main() {
	if err := newRootCommand(context.Background()).Execute(); err != nil {
		log.Fatal(err)
	}
}

func newRootCommand(ctx context.Context) *cobra.Command {
	rootCmd := &cobra.Command{
		Use:           "{{ .AppName }}",
		Short:         "{{ .ProjectName }} command line",
		Args:          cobra.NoArgs,
		SilenceUsage:  true,
		SilenceErrors: true,
		PersistentPreRunE: func(cmd *cobra.Command, args []string) error {
			return configureLogging()
		},
		RunE: func(cmd *cobra.Command, args []string) error {
			return runServe(cmd.Context())
		},
	}
	rootCmd.SetContext(ctx)

	rootCmd.AddCommand(newServeCommand())
	rootCmd.AddCommand(newScheduleCommand())
	rootCmd.AddCommand(newQueueCommand())
	// gos:commands

	return rootCmd
}

func configureLogging() error {
	cfg, err := config.Load()
	if err != nil {
		return err
	}
	logger, err := logging.New(cfg.Log)
	if err != nil {
		return err
	}
	slog.SetDefault(logger)
	return nil
}

func newServeCommand() *cobra.Command {
	return &cobra.Command{
		Use:   "serve",
		Short: "Start HTTP API server",
		Args:  cobra.NoArgs,
		RunE: func(cmd *cobra.Command, args []string) error {
			return runServe(cmd.Context())
		},
	}
}

func newScheduleCommand() *cobra.Command {
	return &cobra.Command{
		Use:   "schedule",
		Short: "Run scheduled jobs",
		Args:  cobra.NoArgs,
		RunE: func(cmd *cobra.Command, args []string) error {
			return runSchedule(cmd.Context())
		},
	}
}

func newQueueCommand() *cobra.Command {
	return &cobra.Command{
		Use:   "queue",
		Short: "Run queue worker",
		Args:  cobra.NoArgs,
		RunE: func(cmd *cobra.Command, args []string) error {
			return runQueue(cmd.Context())
		},
	}
}

func runServe(ctx context.Context) error {
	cfg, err := config.Load()
	if err != nil {
		return err
	}

	application, err := app.New(ctx, cfg)
	if err != nil {
		return err
	}

	return application.Run(ctx)
}

func runSchedule(ctx context.Context) error {
	ctx, stop := signal.NotifyContext(ctx, os.Interrupt, syscall.SIGTERM)
	defer stop()

	if _, err := config.Load(); err != nil {
		return err
	}
	scheduler := worker.NewScheduler(slog.Default(), time.Minute, worker.Task{
		Name: "default",
		Run:  runScheduledJobs,
	})
	return scheduler.Run(ctx)
}

func runScheduledJobs(ctx context.Context) error {
	if err := ctx.Err(); err != nil {
		return err
	}
	slog.DebugContext(ctx, "scheduled jobs tick")
	return nil
}

func runQueue(ctx context.Context) error {
	ctx, stop := signal.NotifyContext(ctx, os.Interrupt, syscall.SIGTERM)
	defer stop()

	if _, err := config.Load(); err != nil {
		return err
	}
	queueWorker := worker.NewQueueWorker(slog.Default(), time.Second, processQueueOnce)
	return queueWorker.Run(ctx)
}

func processQueueOnce(ctx context.Context) error {
	if err := ctx.Err(); err != nil {
		return err
	}
	slog.DebugContext(ctx, "queue worker tick")
	return nil
}
