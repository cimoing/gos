services:
  api:
    build:
      context: ../..
      dockerfile: deployments/docker/Dockerfile
    depends_on:
      - mysql
      - redis
    environment:
      APP_NAME: {{ .AppName }}
      APP_ENV: local
      HTTP_ADDR: :8080
      DB_DRIVER: mysql
      DB_DSN: root:password@tcp(mysql:3306)/{{ .AppName }}?parseTime=true
      REDIS_ADDR: redis:6379
      REDIS_PASSWORD: ""
      REDIS_DB: 0
      LOG_LEVEL: info
    ports:
      - "8080:8080"

  mysql:
    image: mysql:8
    environment:
      MYSQL_ROOT_PASSWORD: password
      MYSQL_DATABASE: {{ .AppName }}
    ports:
      - "3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql

  redis:
    image: redis:7
    ports:
      - "6379:6379"

volumes:
  mysql_data:
