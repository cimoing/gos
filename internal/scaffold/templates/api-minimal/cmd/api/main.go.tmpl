package main

import (
	"context"
	"log"
	"log/slog"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"{{ .ModulePath }}/internal/config"
	httpinterface "{{ .ModulePath }}/internal/interfaces/http"
{{- if .WithOpenTelemetry }}
	"{{ .ModulePath }}/internal/observability"
{{- end }}
	"github.com/spf13/cobra"
	// gos:command-imports
)

func main() {
	if err := newRootCommand(context.Background()).Execute(); err != nil {
		log.Fatal(err)
	}
}

func newRootCommand(ctx context.Context) *cobra.Command {
	rootCmd := &cobra.Command{
		Use:           "{{ .AppName }}",
		Short:         "{{ .ProjectName }} command line",
		Args:          cobra.NoArgs,
		SilenceUsage:  true,
		SilenceErrors: true,
		RunE: func(cmd *cobra.Command, args []string) error {
			return runServe(cmd.Context())
		},
	}
	rootCmd.SetContext(ctx)

	rootCmd.AddCommand(newServeCommand())
	rootCmd.AddCommand(newScheduleCommand())
	rootCmd.AddCommand(newQueueCommand())
	// gos:commands

	return rootCmd
}

func newServeCommand() *cobra.Command {
	return &cobra.Command{
		Use:   "serve",
		Short: "Start HTTP API server",
		Args:  cobra.NoArgs,
		RunE: func(cmd *cobra.Command, args []string) error {
			return runServe(cmd.Context())
		},
	}
}

func newScheduleCommand() *cobra.Command {
	return &cobra.Command{
		Use:   "schedule",
		Short: "Run scheduled jobs",
		Args:  cobra.NoArgs,
		RunE: func(cmd *cobra.Command, args []string) error {
			return runSchedule(cmd.Context())
		},
	}
}

func newQueueCommand() *cobra.Command {
	return &cobra.Command{
		Use:   "queue",
		Short: "Run queue worker",
		Args:  cobra.NoArgs,
		RunE: func(cmd *cobra.Command, args []string) error {
			return runQueue(cmd.Context())
		},
	}
}

func runServe(ctx context.Context) error {
	if err := ctx.Err(); err != nil {
		return err
	}

	cfg := config.Load()
{{ if .WithOpenTelemetry }}
	shutdownTelemetry, err := observability.SetupOpenTelemetry(ctx, cfg.Observability)
	if err != nil {
		return err
	}
	defer func() {
		shutdownCtx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
		defer cancel()
		if err := shutdownTelemetry(shutdownCtx); err != nil {
			log.Printf("shutdown telemetry: %v", err)
		}
	}()

	router := httpinterface.NewRouter(httpinterface.RouterOptions{
		TraceHTTP:   cfg.Observability.Enabled,
		ServiceName: cfg.Observability.ServiceName,
	})
{{- else }}
	router := httpinterface.NewRouter()
{{- end }}

	server := &http.Server{
		Addr:              cfg.HTTPAddr,
		Handler:           router,
		ReadHeaderTimeout: 5 * time.Second,
	}

	log.Printf("http server started addr=%s", cfg.HTTPAddr)
	if err := server.ListenAndServe(); err != nil && err != http.ErrServerClosed {
		return err
	}
	return nil
}

func runSchedule(ctx context.Context) error {
	ctx, stop := signal.NotifyContext(ctx, os.Interrupt, syscall.SIGTERM)
	defer stop()

	logger := slog.New(slog.NewJSONHandler(os.Stdout, nil))
	logger.Info("scheduler started")

	ticker := time.NewTicker(time.Minute)
	defer ticker.Stop()

	runScheduledJobs(ctx, logger)
	for {
		select {
		case <-ctx.Done():
			logger.Info("scheduler stopped")
			return nil
		case <-ticker.C:
			runScheduledJobs(ctx, logger)
		}
	}
}

func runScheduledJobs(ctx context.Context, logger *slog.Logger) {
	if err := ctx.Err(); err != nil {
		return
	}
	logger.Info("scheduled jobs tick")
}

func runQueue(ctx context.Context) error {
	ctx, stop := signal.NotifyContext(ctx, os.Interrupt, syscall.SIGTERM)
	defer stop()

	logger := slog.New(slog.NewJSONHandler(os.Stdout, nil))
	logger.Info("queue worker started")

	ticker := time.NewTicker(time.Second)
	defer ticker.Stop()

	for {
		select {
		case <-ctx.Done():
			logger.Info("queue worker stopped")
			return nil
		case <-ticker.C:
			processQueueOnce(ctx, logger)
		}
	}
}

func processQueueOnce(ctx context.Context, logger *slog.Logger) {
	if err := ctx.Err(); err != nil {
		return
	}
	logger.Debug("queue worker tick")
}
